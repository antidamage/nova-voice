# Deployed server address and satellite identities: see PRIVATEREF.md#1.
NOVA_VOICE_SATELLITE_SERVER_URL=wss://voice-server.local:8766/v1/satellites
NOVA_VOICE_SATELLITE_SATELLITE_ID=linux-satellite
NOVA_VOICE_SATELLITE_DISPLAY_NAME=Linux Satellite
NOVA_VOICE_SATELLITE_ROOM_ID=office
NOVA_VOICE_SATELLITE_CLIENT=linux-native
NOVA_VOICE_SATELLITE_SUPERVISOR=systemd
NOVA_VOICE_SATELLITE_INPUT_DEVICE=default
NOVA_VOICE_SATELLITE_OUTPUT_DEVICE=default
# The installer rewrites /home/satellite-user to the installing user's $HOME.
NOVA_VOICE_SATELLITE_TLS_CA_PATH=/home/satellite-user/.config/nova-voice/tls/ca.crt
NOVA_VOICE_SATELLITE_TLS_CERT_PATH=/home/satellite-user/.config/nova-voice/tls/client.crt
NOVA_VOICE_SATELLITE_TLS_KEY_PATH=/home/satellite-user/.config/nova-voice/tls/client.key
NOVA_VOICE_SATELLITE_HEALTH_PATH=/home/satellite-user/.local/state/nova-voice/health.json
NOVA_VOICE_SATELLITE_ECHO_CANCELLATION=true
NOVA_VOICE_SATELLITE_NOISE_SUPPRESSION=true
NOVA_VOICE_SATELLITE_AUTOMATIC_GAIN_CONTROL=true
