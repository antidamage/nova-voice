NOVA_VOICE_MODE=development
NOVA_VOICE_HOST=0.0.0.0
NOVA_VOICE_PORT=8766
NOVA_VOICE_DATABASE_PATH=/var/lib/nova-voice/transcripts.sqlite3
NOVA_VOICE_RETENTION_HOURS=24
NOVA_VOICE_SHADOW_MODE=true
NOVA_VOICE_PASSIVE_EXECUTION_ENABLED=false
NOVA_VOICE_AUDIO_ENABLED=false
# Explicit, push-to-record development page served at /diagnostics over mTLS.
NOVA_VOICE_DIAGNOSTICS_ENABLED=false
NOVA_VOICE_DIAGNOSTICS_MAX_AUDIO_SECONDS=30
# Used for the 08:00-21:00 daytime playback-volume window and spoken time.
# Set to the household IANA timezone (deployed value: see PRIVATEREF.md#3.3).
NOVA_VOICE_HOUSEHOLD_TIMEZONE=UTC
NOVA_VOICE_PASSIVE_ADDRESSED_THRESHOLD=0.92
NOVA_VOICE_ACTIVE_ADDRESSED_THRESHOLD=0.55
NOVA_VOICE_PASSIVE_INTERPRETATION_THRESHOLD=0.90
NOVA_VOICE_ACTIVE_INTERPRETATION_THRESHOLD=0.65
# Keep command-intent classification in the structured interpretation pass.
# Enabling this legacy prefilter can drop valid commands before interpretation.
NOVA_VOICE_NARROW_GATE_ENABLED=false

# Dashboard base URL (deployed hostname: see PRIVATEREF.md#1.4).
NOVA_VOICE_NOVA_BASE_URL=http://dashboard-host.local
NOVA_VOICE_NOVA_MCP_TOKEN=
NOVA_VOICE_NOVA_CONTRACT_VERSION=nova-provider-v1
NOVA_VOICE_PROVIDER_CONTEXT_TIMEOUT_SECONDS=0.75

NOVA_VOICE_LLM_BASE_URL=http://127.0.0.1:8765/v1
NOVA_VOICE_LLM_MODEL=Qwen3.5-4B
NOVA_VOICE_LLM_TIMEOUT_SECONDS=20
NOVA_VOICE_CONVERSATION_IDLE_SECONDS=20

NOVA_VOICE_STT_MODEL=nvidia/nemotron-speech-streaming-en-0.6b
NOVA_VOICE_STT_MODEL_PATH=/opt/nova-voice/models/nemotron-speech-streaming-en-0.6b/nemotron-speech-streaming-en-0.6b.nemo
NOVA_VOICE_SPEAKER_RECOGNITION_ENABLED=true
NOVA_VOICE_SPEAKER_MODEL=nvidia/speakerverification_en_titanet_large
NOVA_VOICE_SPEAKER_MODEL_PATH=/opt/nova-voice/models/speakerverification-en-titanet-large/speakerverification_en_titanet_large.nemo
NOVA_VOICE_SPEAKER_MATCH_THRESHOLD=0.65
NOVA_VOICE_SPEAKER_MATCH_MARGIN=0.03
NOVA_VOICE_SPEAKER_CLUSTER_THRESHOLD=0.60
NOVA_VOICE_SPEAKER_CONVERSATION_MATCH_THRESHOLD=0.35
NOVA_VOICE_SPEAKER_SHORT_EXECUTE_REQUIRES_RECOGNITION=true
NOVA_VOICE_SPEAKER_SHORT_EXECUTE_MAX_WORDS=4
# Measured operating point; benchmark 160/560 ms before changing production.
NOVA_VOICE_STT_STREAM_CHUNK_MS=160
NOVA_VOICE_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice
NOVA_VOICE_TTS_MODEL_PATH=/opt/nova-voice/models/qwen3-tts-0.6b-customvoice
NOVA_VOICE_TTS_BACKEND=vllm
NOVA_VOICE_TTS_STREAM_BASE_URL=http://127.0.0.1:8091
NOVA_VOICE_TTS_SAMPLE_RATE=24000
NOVA_VOICE_TTS_SPEAKER=Serena
NOVA_VOICE_TTS_LANGUAGE=English
NOVA_VOICE_TTS_DEVICE=cuda
# BF16 on supported GPUs; stable FP32 on Turing/pre-BF16 CUDA devices.
NOVA_VOICE_TTS_DTYPE=auto
# Decode-time context biasing: boosts dashboard wake words + agent name inside
# RNNT decoding (NeMo GPU phrase-boosting tree) so invented names transcribe.
NOVA_VOICE_STT_CONTEXT_BIASING_ENABLED=true
NOVA_VOICE_STT_BOOST_ALPHA=1.0

# CPU-only DeepFilterNet3 sidecar; failures pass raw audio through safely.
NOVA_VOICE_DENOISE_BASE_URL=http://127.0.0.1:8092
# Boot-time fallback only; the dashboard's Voice Agent "response latency"
# sliders (ttsPrerollMs/ttsFrameMs) override both live once the first
# settings pull completes, with no restart required.
NOVA_VOICE_PLAYBACK_PREROLL_MS=700
NOVA_VOICE_TTS_FRAME_MS=100

NOVA_VOICE_PERSONA_PATH=/etc/nova-voice/persona.yaml
NOVA_VOICE_SKILLS_PATH=/opt/nova-voice/skills
NOVA_VOICE_TLS_CERT_PATH=/etc/nova-voice/tls/server.crt
NOVA_VOICE_TLS_KEY_PATH=/etc/nova-voice/tls/server.key
NOVA_VOICE_TLS_CA_PATH=/etc/nova-voice/tls/ca.crt
